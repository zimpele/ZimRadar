# .env.example — copy to .env and fill in values
POSTGRES_PASSWORD=password

# Copernicus Data Space credentials (register at dataspace.copernicus.eu — free)
SENTINELSAT_USER=
SENTINELSAT_PASS=

# NOAA Climate Data Online API key (free token at ncdc.noaa.gov/cdo-web/token)
NOAA_API_KEY=

# OpenRouter — free models at openrouter.ai/keys
# Recommended free models: meta-llama/llama-3.3-70b-instruct:free  or  google/gemma-3-27b-it:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# LLM provider: "auto" (default), "openrouter", or "ollama"
# auto = openrouter if key is set, else ollama
LLM_PROVIDER=auto

# Ollama (local fallback, already running in docker-compose)
OLLAMA_MODEL=gemma2:9b
OLLAMA_URL=http://ollama:11434

# LangSmith (optional — traces agent runs at smith.langchain.com)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=zimradar
LANGCHAIN_TRACING_V2=true

# Composite risk score weights: xgboost_confidence, flood_flag, fire_flag
RISK_SCORE_WEIGHTS=0.6,0.2,0.2

# ZimRadar API auth key (Bearer token for POST /assess)
API_KEY=

# Admin UI credentials (http://<host>:8000/admin)
ADMIN_USER=admin
ADMIN_PASSWORD=
SECRET_KEY=

# Internal service URLs (set automatically in docker-compose, override for local dev)
DATABASE_URL=postgresql+asyncpg://zimradar:password@localhost:5432/zimradar
REDIS_URL=redis://localhost:6379
